---
interface Founder {
	name: string;
	role: string;
	initials: string;
	description: string;
	linkedin?: string;
}

const founders: Founder[] = [
	{
		name: "Nadia Ujovich",
		role: "CEO and Founder",
		initials: "NU",
		description:
			"10+ years of experience in digital marketing. Expertise in SEO, PPC, and content strategy.",
		linkedin: "https://www.linkedin.com/in/nujovich/",
	},
	{
		name: "Gisele Manzano",
		role: "CEO and Founder",
		initials: "GM",
		description:
			"Lorem ipsum dolor sit amet consectetur. At et proin arcu vel. Morbi semper donec luctus quisque. Eget enim tempor ornare non sed. Purus nisl egestas ac quisque adipiscing sodales scelerisque quis. Et platea eu iaculis nullam ac commodo gravida. Gravida sed sagittis nam sapien blandit ut.",
		linkedin: "#",
	},
];
---

<section id="sobre-nosotras" class="py-20 px-6 bg-[#0d0d17]">
	<div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
		<!-- Left column: description -->
		<div class="space-y-6">
			<h2 class="text-4xl font-bold text-white">Sobre Nosotras</h2>
			<p class="text-white/80 text-base leading-relaxed">
				Mermelada tech es una comunidad de tecnología de habla hispana creada y pensada para el
				crecimiento profesional de todas las mujeres que se quieran introducir en el mundo tech.
			</p>
			<p class="text-white/80 text-base leading-relaxed">
				Desde septiembre de 2022 estamos generando espacios colaborativos, desarrollando proyectos
				de codigo abierto y dando charlas con voceras mujeres.
			</p>
			<p class="text-white/80 text-base leading-relaxed">
				Si querés saber más de nosotras te invitamos a que nos contactes por nuestras redes.
			</p>
		</div>

		<!-- Right column: founder cards -->
		<div class="space-y-6">
			{
				founders.map((founder) => (
					<div class="bg-[#1a1a2e] border border-[#2d2d4e] rounded-2xl p-5 flex gap-4 items-start relative">
						<!-- Profile avatar -->
						<div class="relative flex-shrink-0">
							<div class="w-16 h-16 rounded-full bg-grape-dark flex items-center justify-center text-white font-bold text-lg">
								{founder.initials}
							</div>
						</div>
						<!-- Info -->
						<div class="flex-1 min-w-0">
							<div class="flex items-center justify-between mb-1">
								<div>
									<p class="font-bold text-white text-sm">{founder.name}</p>
									<p class="text-white/60 text-xs">{founder.role}</p>
								</div>
								{founder.linkedin && (
									<a
										href={founder.linkedin}
										target="_blank"
										rel="noopener noreferrer"
										aria-label="LinkedIn"
										class="w-8 h-8 rounded-full bg-[#0A66C2] flex items-center justify-center hover:scale-110 transition-transform flex-shrink-0"
									>
										<svg width="14" height="14" viewBox="0 0 24 24" fill="white" aria-hidden="true">
											<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
										</svg>
									</a>
								)}
							</div>
							<p class="text-white/70 text-xs leading-relaxed">{founder.description}</p>
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>
