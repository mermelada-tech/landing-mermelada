---
interface Testimonio {
	name: string;
	role: string;
	quote: string;
	initials: string;
}

const testimonios: Testimonio[] = [
	{
		name: "Ana García",
		role: "Desarrolladora Frontend",
		quote:
			"Mermelada Tech cambió mi perspectiva profesional. Encontré mentoras increíbles y una red de apoyo que nunca imaginé tener en el mundo tech.",
		initials: "AG",
	},
	{
		name: "Laura Rodríguez",
		role: "Estudiante de Ingeniería",
		quote:
			"Gracias a los grupos de estudio pude conseguir mi primera pasantía. La comunidad me dio la confianza que necesitaba para aplicar.",
		initials: "LR",
	},
	{
		name: "María Fernández",
		role: "UX Designer",
		quote:
			"El espacio seguro que describe Mermelada Tech es real. Aquí puedo hacer preguntas sin miedo y aprender a mi ritmo.",
		initials: "MF",
	},
];
---

<section id="testimonios" class="py-20 px-6 bg-white">
	<div class="max-w-6xl mx-auto">
		<div class="text-center mb-12">
			<h2 class="text-5xl font-bold text-grape-dark mb-4">Testimonios</h2>
			<p class="text-blacky text-xl max-w-2xl mx-auto">
				Las voces de nuestra comunidad lo dicen todo.
			</p>
		</div>
		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
			{testimonios.map((t) => (
				<div class="bg-white border border-black rounded-2xl shadow-[4px_6px_0_0_rgba(0,0,0,1)] p-6 flex flex-col gap-4 hover:scale-105 transition-transform">
					<p class="text-blacky text-base leading-relaxed italic flex-1">"{t.quote}"</p>
					<div class="flex items-center gap-3 mt-auto pt-4 border-t border-gray-100">
						<div class="w-10 h-10 rounded-full bg-grape-dark flex items-center justify-center text-white font-bold text-sm flex-shrink-0">
							{t.initials}
						</div>
						<div>
							<p class="font-semibold text-blacky text-sm">{t.name}</p>
							<p class="text-xs text-gray-500">{t.role}</p>
						</div>
					</div>
				</div>
			))}
		</div>
	</div>
</section>
