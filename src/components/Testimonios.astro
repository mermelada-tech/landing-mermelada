---
interface Testimonio {
	name: string;
	role: string;
	quote: string;
	initials: string;
}

const testimonios: Testimonio[] = [
	{
		name: "Ana García",
		role: "Desarrolladora Frontend",
		quote:
			"Mermelada Tech cambió mi perspectiva profesional. Encontré mentoras increíbles y una red de apoyo que nunca imaginé tener en el mundo tech.",
		initials: "AG",
	},
	{
		name: "Laura Rodríguez",
		role: "Estudiante de Ingeniería",
		quote:
			"Gracias a los grupos de estudio pude conseguir mi primera pasantía. La comunidad me dio la confianza que necesitaba para aplicar.",
		initials: "LR",
	},
	{
		name: "María Fernández",
		role: "UX Designer",
		quote:
			"El espacio seguro que describe Mermelada Tech es real. Aquí puedo hacer preguntas sin miedo y aprender a mi ritmo.",
		initials: "MF",
	},
];
---

<section id="testimonios" class="py-20 px-6 bg-white dark:bg-dark-surface transition-colors duration-200">
	<div class="max-w-6xl mx-auto">
		<div class="text-center mb-12">
			<h2 class="text-5xl font-bold text-grape-dark dark:text-light-purple mb-4">Testimonios</h2>
			<p class="text-blacky dark:text-gray-300 text-xl max-w-2xl mx-auto">
				Las voces de nuestra comunidad lo dicen todo.
			</p>
		</div>
		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
			{testimonios.map((t) => (
				<figure class="bg-white dark:bg-dark-bg border border-black dark:border-[#2d2d4e] rounded-2xl shadow-[4px_6px_0_0_rgba(0,0,0,1)] dark:shadow-[4px_6px_0_0_rgba(103,55,115,0.5)] p-6 flex flex-col gap-4 hover:scale-105 transition-transform">
					<blockquote class="text-blacky dark:text-gray-300 text-base leading-relaxed italic flex-1">
						<p>"{t.quote}"</p>
					</blockquote>
					<figcaption class="flex items-center gap-3 mt-auto pt-4 border-t border-gray-100 dark:border-[#2d2d4e]">
						<div aria-hidden="true" class="w-10 h-10 rounded-full bg-grape-dark flex items-center justify-center text-white font-bold text-sm flex-shrink-0">
							{t.initials}
						</div>
						<div>
							<p class="font-semibold text-blacky dark:text-white text-sm">{t.name}</p>
							<p class="text-xs text-gray-500 dark:text-gray-400">{t.role}</p>
						</div>
					</figcaption>
				</figure>
			))}
		</div>
	</div>
</section>
