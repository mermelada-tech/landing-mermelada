---
interface FAQ {
	question: string;
	answer: string;
}

const faqs: FAQ[] = [
	{
		question: "¿Quiénes pueden unirse a la comunidad?",
		answer:
			"La comunidad está abierta especialmente a todas las mujeres de habla hispana, independientemente de su edad, raza, origen étnico, orientación sexual o identidad de género. También pueden unirse todos aquellos que quieran formar parte, siempre que se mantenga el respeto y la empatía.",
	},
	{
		question: "¿Hay algún costo para unirse?",
		answer:
			"La comunidad es gratuita para unirse. Existe la posibilidad de colaborar con nosotras a través del link de Patreon.",
	},
	{
		question: "¿Qué recursos y oportunidades ofrece la comunidad?",
		answer:
			"Dentro de la comunidad ofrecemos espacios colaborativos para trabajar en proyectos de código abierto, eventos virtuales sobre temas de tecnología y cursos y prácticas en el canal de YouTube y Twitch de Mermelada Tech.",
	},
	{
		question: "¿Cómo puedo unirme a la comunidad?",
		answer:
			"Puedes unirte a través de nuestro servidor de Discord. Encontrarás el link en nuestra bio de redes sociales o escribiéndonos directamente.",
	},
	{
		question: "¿Cómo puedo obtener más información?",
		answer:
			"Para obtener más información podés enviarnos un mensaje directo a través de nuestras redes sociales o escribirnos por e-mail a mermelada.tech@gmail.com.",
	},
];
---

<section id="faqs" class="py-20 px-6 bg-white">
	<div class="max-w-3xl mx-auto">
		<div class="text-center mb-12">
			<h2 class="text-4xl font-bold text-blacky mb-2">Preguntas frecuentes</h2>
		</div>
		<div class="flex flex-col gap-3">
			{
				faqs.map((faq) => (
					<details class="bg-white border border-black rounded-2xl shadow-[4px_6px_0_0_rgba(0,0,0,1)] group">
						<summary class="flex justify-between items-center p-5 font-semibold text-blacky cursor-pointer list-none gap-4">
							<span class="text-sm sm:text-base">{faq.question}</span>
							<span class="flex-shrink-0 w-8 h-8 rounded-full bg-grape-dark text-white flex items-center justify-center text-xl leading-none group-open:rotate-45 transition-transform duration-200">
								+
							</span>
						</summary>
						<div class="px-5 pb-5">
							<p class="text-gray-600 leading-relaxed text-sm">{faq.answer}</p>
						</div>
					</details>
				))
			}
		</div>
	</div>
</section>
