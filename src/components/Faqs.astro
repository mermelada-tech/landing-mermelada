---
interface FAQ {
	question: string;
	answer: string;
}

const faqs: FAQ[] = [
	{
		question: "¿Quiénes pueden unirse a la comunidad?",
		answer:
			"Cualquier mujer interesada en tecnología, sin importar su nivel de experiencia.",
	},
	{
		question: "¿Hay algún costo para unirse?",
		answer:
			"La comunidad es gratuita pero, si te gusta lo que hacemos y querés colaborar, podés hacerlo a través de Patreon o Cafecito.",
	},
	{
		question: "¿Qué recursos y oportunidades ofrecen?",
		answer:
			"Espacios colaborativos para trabajar en proyectos de código abierto. Eventos virtuales sobre tecnología. Cursos y prácticas en el canal de YouTube y Twitch.",
	},
	{
		question: "¿Cómo puedo unirme a la comunidad?",
		answer:
			"Te esperamos en nuestro Discord — entrá por el link que aparece en la navegación.",
	},
	{
		question: "¿Cómo puedo obtener más información?",
		answer: "Escribinos a mermelada.tech@gmail.com y respondemos con gusto.",
	},
];
---

<section id="faqs" class="py-20 px-[212px] bg-paper dark:bg-dark-bg transition-colors duration-200">
	<h2 class="text-grape-dark font-bold text-4xl text-center mb-10">Preguntas frecuentes</h2>

	<div class="max-w-[834px] mx-auto flex flex-col gap-1.5">
		{faqs.map((faq, i) => (
			<div class="faq-item" data-index={i}>
				<button
					class="faq-question w-full bg-periwinkle dark:bg-[#2a1f3d] border-[1.5px] border-lilac rounded-[8px] px-4 pr-14 py-3.5 font-body text-sm text-blacky dark:text-white text-left relative hover:brightness-[0.97] transition-[filter] cursor-pointer"
					aria-expanded={i === 0 ? "true" : "false"}
				>
					<span>{faq.question}</span>
					<!-- Toggle dot -->
					<span
						class="faq-dot absolute right-3.5 top-1/2 -translate-y-1/2 w-[26px] h-[26px] rounded-full bg-mint border border-blacky shadow-[2px_2px_0_0_#1b1b1b] flex items-center justify-center"
						aria-hidden="true"
					>
						<!-- Horizontal bar always visible -->
						<span class="absolute w-2.5 h-0.5 bg-blacky rounded-sm"></span>
						<!-- Vertical bar hidden when open -->
						<span class="faq-dot-v absolute w-0.5 h-2.5 bg-blacky rounded-sm transition-opacity duration-150"></span>
					</span>
				</button>
				<div class="faq-answer px-4 pb-1.5 pt-2.5 font-display text-sm text-ink-2 dark:text-gray-300 leading-relaxed" hidden={i !== 0}>
					{faq.answer}
				</div>
			</div>
		))}
	</div>
</section>

<script>
	document.querySelectorAll<HTMLElement>(".faq-item").forEach((item) => {
		const btn = item.querySelector<HTMLButtonElement>(".faq-question")!;
		const answer = item.querySelector<HTMLElement>(".faq-answer")!;
		const vertBar = btn.querySelector<HTMLElement>(".faq-dot-v")!;

		btn.addEventListener("click", () => {
			const isOpen = btn.getAttribute("aria-expanded") === "true";

			// Close all
			document.querySelectorAll<HTMLButtonElement>(".faq-question").forEach((b) => {
				b.setAttribute("aria-expanded", "false");
				b.closest<HTMLElement>(".faq-item")!.querySelector<HTMLElement>(".faq-answer")!.hidden = true;
				b.querySelector<HTMLElement>(".faq-dot-v")!.style.opacity = "1";
			});

			// Open if was closed
			if (!isOpen) {
				btn.setAttribute("aria-expanded", "true");
				answer.hidden = false;
				vertBar.style.opacity = "0";
			}
		});

		// Init first item
		if (btn.getAttribute("aria-expanded") === "true") {
			vertBar.style.opacity = "0";
		}
	});
</script>
