---
---

<header>
	<nav
		class="flex justify-between items-center h-[64px] bg-white dark:bg-dark-bg border-b border-black dark:border-[#2d2d4e] px-4 transition-colors duration-200"
	>
		<!-- Logo -->
		<a href="/" aria-label="Mermelada Tech — inicio">
			<img src="/logo-mermelada.svg" alt="Mermelada Tech" class="m-2 h-10 w-auto dark:brightness-0 dark:invert" />
		</a>

		<!-- Desktop nav links -->
		<ul class="hidden md:flex items-center list-none gap-1">
			<li>
				<a
					href="/"
					class="px-3 py-2 font-medium text-blacky dark:text-white hover:text-grape-dark dark:hover:text-light-purple transition-colors"
					>Inicio</a
				>
			</li>
			<li>
				<a
					href="#mentorias"
					class="px-3 py-2 font-medium text-blacky dark:text-white hover:text-grape-dark dark:hover:text-light-purple transition-colors"
					>Mentorías</a
				>
			</li>
			<li>
				<a
					href="#testimonios"
					class="px-3 py-2 font-medium text-blacky dark:text-white hover:text-grape-dark dark:hover:text-light-purple transition-colors"
					>Testimonios</a
				>
			</li>
			<li>
				<a
					href="#sobre-nosotras"
					class="px-3 py-2 font-medium text-blacky dark:text-white hover:text-grape-dark dark:hover:text-light-purple transition-colors"
					>Sobre Nosotras</a
				>
			</li>
			<li>
				<a
					href="#colaboradoras"
					class="px-3 py-2 font-medium text-blacky dark:text-white hover:text-grape-dark dark:hover:text-light-purple transition-colors"
					>Colaboradoras</a
				>
			</li>
			<li>
				<a
					href="#faqs"
					class="px-3 py-2 font-medium text-blacky dark:text-white hover:text-grape-dark dark:hover:text-light-purple transition-colors"
					>FAQs</a
				>
			</li>
		</ul>

		<!-- Right controls (always visible) -->
		<div class="flex items-center gap-2">
			<!-- Dark mode toggle -->
			<button
				id="theme-toggle"
				aria-label="Cambiar tema"
				class="w-9 h-9 flex items-center justify-center rounded-full border border-black dark:border-[#2d2d4e] text-blacky dark:text-white hover:scale-105 transition-transform"
			>
				<!-- Moon icon — visible in light mode -->
				<svg
					class="block dark:hidden"
					xmlns="http://www.w3.org/2000/svg"
					width="18"
					height="18"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
				>
					<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
				</svg>
				<!-- Sun icon — visible in dark mode -->
				<svg
					class="hidden dark:block"
					xmlns="http://www.w3.org/2000/svg"
					width="18"
					height="18"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
				>
					<circle cx="12" cy="12" r="5"></circle>
					<line x1="12" y1="1" x2="12" y2="3"></line>
					<line x1="12" y1="21" x2="12" y2="23"></line>
					<line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
					<line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
					<line x1="1" y1="12" x2="3" y2="12"></line>
					<line x1="21" y1="12" x2="23" y2="12"></line>
					<line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
					<line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
				</svg>
			</button>

			<!-- Patreon button — hidden on mobile, visible on desktop -->
			<a
				href="https://www.patreon.com/mermelada"
				target="_blank"
				rel="noopener noreferrer"
				class="hidden md:flex bg-yellow-sunflower border border-black rounded-xs shadow-[4px_6px_0_0_rgba(0,0,0,1)] dark:shadow-[4px_6px_0_0_rgba(103,55,115,0.6)] transform hover:scale-105 transition-transform items-center py-1 px-3 font-semibold gap-2"
			>
				<span>Patreon</span>
				<img src="/logo-patreon.svg" alt="" aria-hidden="true" class="w-4 h-4" />
			</a>

			<!-- Hamburger button — mobile only -->
			<button
				id="mobile-menu-toggle"
				aria-label="Abrir menú"
				aria-expanded="false"
				aria-controls="mobile-menu"
				class="flex md:hidden w-9 h-9 items-center justify-center rounded-full border border-black dark:border-[#2d2d4e] text-blacky dark:text-white hover:scale-105 transition-transform"
			>
				<!-- Hamburger icon (shown when menu is closed) -->
				<svg
					data-icon="hamburger"
					class="block"
					xmlns="http://www.w3.org/2000/svg"
					width="18"
					height="18"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
				>
					<line x1="3" y1="6" x2="21" y2="6"></line>
					<line x1="3" y1="12" x2="21" y2="12"></line>
					<line x1="3" y1="18" x2="21" y2="18"></line>
				</svg>
				<!-- Close icon (shown when menu is open) -->
				<svg
					data-icon="close"
					class="hidden"
					xmlns="http://www.w3.org/2000/svg"
					width="18"
					height="18"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
				>
					<line x1="18" y1="6" x2="6" y2="18"></line>
					<line x1="6" y1="6" x2="18" y2="18"></line>
				</svg>
			</button>
		</div>
	</nav>

	<!-- Mobile dropdown menu -->
	<div
		id="mobile-menu"
		class="hidden md:hidden bg-white dark:bg-dark-bg border-b border-black dark:border-[#2d2d4e] transition-colors duration-200"
	>
		<ul class="flex flex-col px-4 py-2">
			<li>
				<a
					href="/"
					class="block py-3 font-medium text-blacky dark:text-white hover:text-grape-dark dark:hover:text-light-purple transition-colors border-b border-gray-100 dark:border-[#2d2d4e]"
					>Inicio</a
				>
			</li>
			<li>
				<a
					href="#mentorias"
					class="block py-3 font-medium text-blacky dark:text-white hover:text-grape-dark dark:hover:text-light-purple transition-colors border-b border-gray-100 dark:border-[#2d2d4e]"
					>Mentorías</a
				>
			</li>
			<li>
				<a
					href="#testimonios"
					class="block py-3 font-medium text-blacky dark:text-white hover:text-grape-dark dark:hover:text-light-purple transition-colors border-b border-gray-100 dark:border-[#2d2d4e]"
					>Testimonios</a
				>
			</li>
			<li>
				<a
					href="#sobre-nosotras"
					class="block py-3 font-medium text-blacky dark:text-white hover:text-grape-dark dark:hover:text-light-purple transition-colors border-b border-gray-100 dark:border-[#2d2d4e]"
					>Sobre Nosotras</a
				>
			</li>
			<li>
				<a
					href="#colaboradoras"
					class="block py-3 font-medium text-blacky dark:text-white hover:text-grape-dark dark:hover:text-light-purple transition-colors border-b border-gray-100 dark:border-[#2d2d4e]"
					>Colaboradoras</a
				>
			</li>
			<li>
				<a
					href="#faqs"
					class="block py-3 font-medium text-blacky dark:text-white hover:text-grape-dark dark:hover:text-light-purple transition-colors border-b border-gray-100 dark:border-[#2d2d4e]"
					>FAQs</a
				>
			</li>
			<li class="py-3">
				<a
					href="https://www.patreon.com/mermelada"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex bg-yellow-sunflower border border-black rounded-xs shadow-[4px_6px_0_0_rgba(0,0,0,1)] dark:shadow-[4px_6px_0_0_rgba(103,55,115,0.6)] hover:scale-105 transition-transform items-center py-1 px-3 font-semibold gap-2"
				>
					<span>Patreon</span>
					<img src="/logo-patreon.svg" alt="" aria-hidden="true" class="w-4 h-4" />
				</a>
			</li>
		</ul>
	</div>
</header>

<script>
	const themeToggle = document.getElementById("theme-toggle");
	themeToggle?.addEventListener("click", () => {
		const isDark = document.documentElement.classList.toggle("dark");
		localStorage.setItem("theme", isDark ? "dark" : "light");
	});

	const menuToggle = document.getElementById("mobile-menu-toggle");
	const mobileMenu = document.getElementById("mobile-menu");
	const hamburgerIcon = menuToggle?.querySelector("[data-icon='hamburger']");
	const closeIcon = menuToggle?.querySelector("[data-icon='close']");

	menuToggle?.addEventListener("click", () => {
		const isOpen = mobileMenu?.classList.toggle("hidden") === false;
		menuToggle.setAttribute("aria-expanded", String(isOpen));
		hamburgerIcon?.classList.toggle("hidden", isOpen);
		closeIcon?.classList.toggle("hidden", !isOpen);
	});

	mobileMenu?.querySelectorAll("a").forEach((link) => {
		link.addEventListener("click", () => {
			mobileMenu.classList.add("hidden");
			menuToggle?.setAttribute("aria-expanded", "false");
			hamburgerIcon?.classList.remove("hidden");
			closeIcon?.classList.add("hidden");
		});
	});
</script>
