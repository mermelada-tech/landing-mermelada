---
interface Founder {
	name: string;
	role: string;
	bio: string;
	img: string;
	linkedin: string;
}

const founders: Founder[] = [
	{
		name: "Nadia Ujovich",
		role: "CEO and Founder",
		bio: "Cofundadora de Mermelada Tech. Apasionada por crear espacios inclusivos donde las mujeres puedan crecer en tecnología y construir carrera con apoyo real.",
		img: "/founder-nadia.jpg",
		linkedin: "https://linkedin.com/in/nadiaujovich",
	},
	{
		name: "Gisele Manzano",
		role: "CEO and Founder",
		bio: "Cofundadora de Mermelada Tech. Convencida de que la diversidad en tech no es un bonus, es la base. Trabaja para que más mujeres encuentren su lugar en la industria.",
		img: "/founder-gisele.jpg",
		linkedin: "https://linkedin.com/in/giselemanzano",
	},
];

const collaboratorColors = [
	"hsl(260,40%,70%)",
	"hsl(280,40%,70%)",
	"hsl(300,40%,70%)",
	"hsl(320,40%,70%)",
	"hsl(340,40%,70%)",
];
---

<section id="sobre-nosotras" class="py-20 px-[94px] bg-periwinkle dark:bg-dark-surface transition-colors duration-200">
	<div class="grid grid-cols-1 lg:grid-cols-2 gap-[72px]">

		<!-- Left: about + collaborators -->
		<div id="colaboradoras">
			<h2 class="text-grape-dark font-bold text-4xl mb-6">Colaboradores</h2>

			<p class="text-ink-2 dark:text-gray-300 text-base leading-relaxed mb-4">
				Mermelada tech es una comunidad de tecnología de habla hispana creada y pensada para el
				crecimiento profesional de todas las mujeres que se quieran introducir en el mundo tech.
			</p>
			<p class="text-ink-2 dark:text-gray-300 text-base leading-relaxed mb-4">
				Desde septiembre de 2022 estamos generando espacios colaborativos, desarrollando
				proyectos de código abierto y dando charlas con voceras mujeres.
			</p>
			<p class="text-ink-2 dark:text-gray-300 text-base leading-relaxed">
				Si querés saber más de nosotras te invitamos a que nos contactes por nuestras redes.
			</p>

			<!-- Placeholder collaborator avatars -->
			<div class="flex gap-3 mt-8">
				{collaboratorColors.map((color) => (
					<div
						class="w-16 h-16 rounded-full border border-blacky dark:border-light-purple flex-shrink-0"
						style={`background: ${color};`}
					/>
				))}
			</div>

			<div class="flex flex-wrap gap-4 mt-9">
				<a
					href="mailto:mermelada.tech@gmail.com"
					class="inline-flex items-center gap-2 bg-snow dark:bg-dark-bg text-blacky dark:text-white font-bold text-base border-[1.5px] border-blacky dark:border-light-purple rounded-[8px] shadow-[4px_4px_0_0_#1b1b1b] dark:shadow-[4px_4px_0_0_#ab7bb7] px-4 py-[10px] hover:-translate-x-px hover:-translate-y-px hover:shadow-[5px_5px_0_0_#1b1b1b] active:translate-x-[3px] active:translate-y-[3px] active:shadow-[1px_1px_0_0_#1b1b1b] transition-[transform,box-shadow] duration-[120ms]"
				>
					¡Quiero ser colaborador!
				</a>
				<a
					href="#sobre-nosotras"
					class="inline-flex items-center gap-2 bg-mint text-blacky font-bold text-base border-[1.5px] border-blacky rounded-[8px] shadow-[4px_4px_0_0_#1b1b1b] px-4 py-[10px] hover:-translate-x-px hover:-translate-y-px hover:shadow-[5px_5px_0_0_#1b1b1b] active:translate-x-[3px] active:translate-y-[3px] active:shadow-[1px_1px_0_0_#1b1b1b] transition-[transform,box-shadow] duration-[120ms]"
				>
					Conocé a los colaboradores
				</a>
			</div>
		</div>

		<!-- Right: founder cards -->
		<div class="flex flex-col gap-8">
			{founders.map((f) => (
				<article class="bg-snow dark:bg-dark-bg border border-[#e6f2f7] dark:border-[#2d2d4e] rounded-[45px] shadow-[0_4px_0_0_#ab7bb7] p-8 flex items-center gap-5 relative">
					<img
						src={f.img}
						alt={f.name}
						class="w-24 h-24 rounded-full object-cover object-center border-2 border-[#231f20] flex-shrink-0"
					/>
					<div class="flex-1 min-w-0">
						<div class="font-bold text-xl text-grape-dark dark:text-lilac">{f.name}</div>
						<div class="text-base text-ink-2 dark:text-gray-300 mt-1">{f.role}</div>
						<hr class="border-0 border-t border-ink-2 dark:border-[#2d2d4e] my-4" />
						<p class="text-sm text-ink-2 dark:text-gray-400 leading-snug">{f.bio}</p>
					</div>
					<a
						href={f.linkedin}
						target="_blank"
						rel="noopener noreferrer"
						aria-label={`LinkedIn de ${f.name}`}
						class="absolute right-9 top-8 w-[34px] h-[34px] rounded-full bg-ink-2 flex items-center justify-center flex-shrink-0 hover:opacity-80 transition-opacity"
					>
						<img
							src="https://api.iconify.design/bi/linkedin.svg?color=%23ab7bb7"
							width="16"
							alt=""
							aria-hidden="true"
						/>
					</a>
				</article>
			))}
		</div>
	</div>
</section>
