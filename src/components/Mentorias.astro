---
---

<section id="mentorias" class="py-20 px-6 bg-[#0d0d17]">
	<div class="max-w-3xl mx-auto text-center">
		<h2 class="text-4xl font-bold text-white mb-4">Sumate al programa de mentorías tech</h2>
		<p class="text-white/70 text-lg mb-10">
			Para que puedas tener como guía la experiencia de otras mujeres en Tecnología
		</p>

		<!-- Tabs -->
		<div class="flex justify-center gap-3 mb-10">
			<button
				id="tab-mentoras"
				class="px-8 py-2 font-semibold border border-white rounded-xs text-blacky bg-white shadow-[4px_6px_0_0_rgba(0,0,0,1)] hover:scale-105 transition-transform"
			>
				Mentoras
			</button>
			<button
				id="tab-mentees"
				class="px-8 py-2 font-semibold border border-white rounded-xs text-white bg-transparent hover:bg-white hover:text-blacky transition-colors"
			>
				Mentees
			</button>
		</div>

		<!-- Mentoras card -->
		<div
			id="panel-mentoras"
			class="bg-white border border-black rounded-2xl shadow-[4px_6px_0_0_rgba(0,0,0,1)] p-8 text-left"
		>
			<h3 class="text-xl font-bold text-blacky mb-4">
				¿Te gustaría compartir tu experiencia y acompañar a otras mujeres a alcanzar sus metas?
			</h3>
			<p class="text-gray-700 leading-relaxed mb-4">
				En Mermelada Tech ofrecemos un programa de mentorías para que mujeres con experiencia en la
				industria puedan ayudar a otras a desarrollar sus carreras.
			</p>
			<p class="text-gray-700 leading-relaxed mb-4">
				Si estás interesada en participar como mentora, envíanos un correo electrónico a
				[dirección de correo electrónico] con un breve resumen de tu experiencia en tecnología y
				tus intereses en mentoring.
			</p>
			<p class="text-gray-700 leading-relaxed mb-8">
				¡Únete a nosotros y ayuda a crear un futuro más inclusivo para las mujeres en tecnología!
			</p>
			<div class="flex justify-center">
				<a
					href="mailto:mermelada.tech@gmail.com"
					class="inline-block bg-white border border-black rounded-xs shadow-[4px_6px_0_0_rgba(0,0,0,1)] px-8 py-3 font-semibold hover:scale-105 transition-transform"
				>
					¡Quiero ser mentora tech!
				</a>
			</div>
		</div>

		<!-- Mentees card (hidden by default) -->
		<div
			id="panel-mentees"
			class="hidden bg-white border border-black rounded-2xl shadow-[4px_6px_0_0_rgba(0,0,0,1)] p-8 text-left"
		>
			<h3 class="text-xl font-bold text-blacky mb-4">
				¿Te gustaría recibir la guía de otras mujeres con más experiencia en la industria?
			</h3>
			<p class="text-gray-700 leading-relaxed mb-4">
				En Mermelada Tech conectamos mujeres que quieren crecer con quienes ya recorrieron el
				camino. Nuestras mentoras te ayudarán a definir objetivos y avanzar en tu carrera.
			</p>
			<p class="text-gray-700 leading-relaxed mb-8">
				¡Únete a nosotros y empieza a desarrollar tu carrera en tecnología con el apoyo que
				necesitas!
			</p>
			<div class="flex justify-center">
				<a
					href="https://discord.gg/mermelada"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-block bg-white border border-black rounded-xs shadow-[4px_6px_0_0_rgba(0,0,0,1)] px-8 py-3 font-semibold hover:scale-105 transition-transform"
				>
					¡Quiero coordinar una mentoría!
				</a>
			</div>
		</div>
	</div>
</section>

<script>
	const tabMentoras = document.getElementById("tab-mentoras");
	const tabMentees = document.getElementById("tab-mentees");
	const panelMentoras = document.getElementById("panel-mentoras");
	const panelMentees = document.getElementById("panel-mentees");

	tabMentoras?.addEventListener("click", () => {
		panelMentoras?.classList.remove("hidden");
		panelMentees?.classList.add("hidden");
		tabMentoras.className =
			"px-8 py-2 font-semibold border border-white rounded-xs text-blacky bg-white shadow-[4px_6px_0_0_rgba(0,0,0,1)] hover:scale-105 transition-transform";
		if (tabMentees) {
			tabMentees.className =
				"px-8 py-2 font-semibold border border-white rounded-xs text-white bg-transparent hover:bg-white hover:text-blacky transition-colors";
		}
	});

	tabMentees?.addEventListener("click", () => {
		panelMentees?.classList.remove("hidden");
		panelMentoras?.classList.add("hidden");
		tabMentees.className =
			"px-8 py-2 font-semibold border border-white rounded-xs text-blacky bg-white shadow-[4px_6px_0_0_rgba(0,0,0,1)] hover:scale-105 transition-transform";
		if (tabMentoras) {
			tabMentoras.className =
				"px-8 py-2 font-semibold border border-white rounded-xs text-white bg-transparent hover:bg-white hover:text-blacky transition-colors";
		}
	});
</script>
