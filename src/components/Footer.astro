---
---

<footer class="bg-[#0d0d17] text-white py-8 px-6">
	<div class="max-w-6xl mx-auto">
		<!-- Main footer row -->
		<div class="flex flex-col sm:flex-row justify-between items-center gap-6 pb-6 border-b border-white/10">
			<!-- Logo -->
			<img
				src="/logo-mermelada.svg"
				alt="Mermelada Tech"
				class="h-10 w-auto brightness-0 invert"
			/>

			<!-- Social icons -->
			<div class="flex items-center gap-4">
				<!-- LinkedIn -->
				<a
					href="https://www.linkedin.com/company/mermelada-tech/"
					target="_blank"
					rel="noopener noreferrer"
					aria-label="LinkedIn"
					class="text-white/70 hover:text-white transition-colors"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="22"
						height="22"
						viewBox="0 0 24 24"
						fill="currentColor"
						aria-hidden="true"
					>
						<path
							d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
						></path>
					</svg>
				</a>
				<!-- X / Twitter -->
				<a
					href="https://twitter.com/mermelada_tech"
					target="_blank"
					rel="noopener noreferrer"
					aria-label="X / Twitter"
					class="text-white/70 hover:text-white transition-colors"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="20"
						height="20"
						viewBox="0 0 24 24"
						fill="currentColor"
						aria-hidden="true"
					>
						<path
							d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.261 5.632 5.903-5.632zm-1.161 17.52h1.833L7.084 4.126H5.117z"
						></path>
					</svg>
				</a>
				<!-- GitHub -->
				<a
					href="https://github.com/mermelada-tech"
					target="_blank"
					rel="noopener noreferrer"
					aria-label="GitHub"
					class="text-white/70 hover:text-white transition-colors"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="22"
						height="22"
						viewBox="0 0 24 24"
						fill="currentColor"
						aria-hidden="true"
					>
						<path
							d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
						></path>
					</svg>
				</a>
				<!-- YouTube -->
				<a
					href="https://www.youtube.com/@mermelada"
					target="_blank"
					rel="noopener noreferrer"
					aria-label="YouTube"
					class="text-white/70 hover:text-white transition-colors"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="currentColor"
						aria-hidden="true"
					>
						<path
							d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
						></path>
					</svg>
				</a>
				<!-- Twitch -->
				<a
					href="https://www.twitch.tv/mermelada"
					target="_blank"
					rel="noopener noreferrer"
					aria-label="Twitch"
					class="text-white/70 hover:text-white transition-colors"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="20"
						height="20"
						viewBox="0 0 24 24"
						fill="currentColor"
						aria-hidden="true"
					>
						<path
							d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z"
						></path>
					</svg>
				</a>
			</div>
		</div>

		<!-- Bottom row -->
		<div class="flex flex-col sm:flex-row justify-between items-center gap-4 pt-6">
			<p class="text-white/50 text-sm">
				© 2024 · Hecho con ♥ y Astro
			</p>
			<a
				href="https://discord.gg/mermelada"
				target="_blank"
				rel="noopener noreferrer"
				class="bg-yellow-sunflower text-blacky border border-black rounded-xs shadow-[4px_6px_0_0_rgba(0,0,0,1)] px-6 py-2 font-semibold hover:scale-105 transition-transform text-sm"
			>
				Súmate a la comunidad
			</a>
		</div>
	</div>
</footer>
