---
import NavBar from '../components/NavBar.astro';
import "../styles/global.css";

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Mermelada Tech — comunidad de mujeres en tecnología. Aprende, crece y conecta con otras mujeres apasionadas por la tecnología." } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<NavBar />
		<slot />
	</body>
</html>
